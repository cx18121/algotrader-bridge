# ===================================================================
# AlgoTrader Bridge — Environment Configuration
# Copy to .env and edit. All values shown are defaults unless marked REQUIRED.
# ===================================================================

# --- Webhook ---
# REQUIRED. Shared secret for webhook authentication. Min 32 chars recommended.
WEBHOOK_SECRET=change_me_min_32_chars_recommended

# --- IB Gateway credentials (Docker / VPS only) ---
IB_USERNAME=your_ibkr_username
IB_PASSWORD=your_ibkr_password
TRADING_MODE=paper     # paper or live
VNC_PASSWORD=changeme  # password for noVNC web UI at :6080

# --- Deployment guardrails ---
# Live mode is fail-closed: TRADING_MODE=live will not start unless this is true.
LIVE_TRADING_ENABLED=false
# Required in live mode. Use the exact IBKR account id expected for this VPS
# so the bridge refuses to run if paper/live credentials or ports are crossed.
# EXPECTED_IBKR_ACCOUNT=U1234567
# Optional comma-separated allowlist. If set, entry signals for any other symbol
# are rejected before order placement.
# ALLOWED_SYMBOLS=MES,MNQ,MBT

# --- TWS / IBKR ---
# Local TWS: TWS_HOST=127.0.0.1, TWS_PORT=7497
# Docker IB Gateway (paper): TWS_HOST=127.0.0.1, TWS_PORT=4002
# Docker IB Gateway (live):  TWS_HOST=127.0.0.1, TWS_PORT=4001
TWS_HOST=127.0.0.1
TWS_PORT=4002          # 7497=TWS paper, 7496=TWS live, 4002=Gateway paper, 4001=Gateway live
TWS_CLIENT_ID=1
TWS_RECONNECT_INTERVAL_SECONDS=10

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Storage ---
DB_PATH=./trading.db

# --- Logging ---
LOG_LEVEL=INFO

# --- Default order sizing ---
DEFAULT_QTY=1
# SYMBOL_QTY_SPY=10
# SYMBOL_INTERVAL_QTY_SPY_15m=10

# --- Trailing stop ---
TRAIL_OFFSET_POINTS=50
# TRAIL_OFFSET_POINTS_AAPL=5
# Set to true when TradingView's Pine strategy.exit trailing stops drive closes
# via webhook alerts — prevents the bridge from placing its own IBKR TRAIL order
# on entry fills (avoids double-exits).
DISABLE_TRAIL=false

# --- Risk limits ---
MAX_POSITION_SIZE=1000
MAX_OPEN_POSITIONS=10
# Set >0 to stop opening new positions after realized P&L for the UTC day
# reaches this loss. Example: 250 rejects new entries at -$250 realized P&L.
MAX_DAILY_REALIZED_LOSS=0

# --- Deduplication ---
DEDUP_WINDOW_SECONDS=5

# --- Behavior toggles ---
IGNORE_SHORT_SIGNALS=false

# --- Dashboard auth ---
# Values: ip_allowlist, basic_auth, none
DASHBOARD_AUTH=ip_allowlist
DASHBOARD_ALLOWED_IPS=127.0.0.1
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=change_me

# --- Account snapshots ---
ACCOUNT_SNAPSHOT_INTERVAL_SECONDS=300

# --- Maintenance window (primary daily) ---
MAINTENANCE_WINDOW_ENABLED=true
MAINTENANCE_WINDOW_START=23:45
MAINTENANCE_WINDOW_END=00:15
MAINTENANCE_CLOSE_MINUTES_BEFORE=5
MAINTENANCE_TIMEZONE=America/New_York

# --- Maintenance window 2 (secondary daily, e.g. mid-day break) ---
MAINTENANCE_WINDOW_2_ENABLED=false
MAINTENANCE_WINDOW_2_START=17:00
MAINTENANCE_WINDOW_2_END=18:00

# --- Maintenance window 3 (weekly/weekend) ---
MAINTENANCE_WEEKEND_ENABLED=false
MAINTENANCE_WEEKEND_START_DAY=friday
MAINTENANCE_WEEKEND_START_TIME=16:00
MAINTENANCE_WEEKEND_END_DAY=sunday
MAINTENANCE_WEEKEND_END_TIME=17:00

# --- Contract mapping ---
# JSON object keyed by base symbol (TradingView "N!" suffixes like "1!"/"2!" are
# stripped before lookup — e.g. "MBT1!" looks up "MBT"). Values specify the IBKR
# contract: sec_type is one of "cont_future" (continuous front-month future),
# "future" (requires last_trade_date YYYYMM or YYYYMMDD), or "stock" (default).
# Symbols not listed here default to Stock(SMART, USD).
# Example:
# CONTRACT_MAP={"MBT":{"sec_type":"cont_future","exchange":"CME","currency":"USD"},"MES":{"sec_type":"cont_future","exchange":"CME","currency":"USD"},"MNQ":{"sec_type":"cont_future","exchange":"CME","currency":"USD"}}
CONTRACT_MAP=

# --- Order replacement ---
# Values: "add", "replace"
PARTIAL_FILL_REPLACEMENT_MODE=add

# --- Rate limit ---
WEBHOOK_RATE_LIMIT_RPS=10
